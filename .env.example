# ── Anthropic ─────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ────────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Optional: override the price ID. Defaults to price_1TRlBQKyPrmclvwmo8coeL30 in code.
STRIPE_PRICE_ID=price_1TRlBQKyPrmclvwmo8coeL30
# From https://dashboard.stripe.com/test/webhooks after adding the webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MailerLite ────────────────────────────────────────────
# https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=eyJ0eXAi...
MAILERLITE_GROUP_ID=186146320578250286

# ── Resend ────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# From-address for the results email. Requires a verified domain in Resend.
# Leave unset to use the default (SLP Transitions <results@slptransitions.com>).
# For pre-verification testing: "SLP Transitions <onboarding@resend.dev>"
# (Resend sandbox — only delivers to the account owner's email address).
RESEND_FROM=

# ── Upstash Redis (auto-populated by Vercel Marketplace integration) ──
# Required when stashed inputs exceed Stripe metadata limit (~7KB)
# Enable from Vercel project → Storage → Marketplace → Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy KV_* names are also supported (the code reads both)

# ── App URL ───────────────────────────────────────────────
# Used in emails and as the success_url base. Set to your custom domain in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000
